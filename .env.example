# =============================================================================
# syifa configuration template
# Copy to .env and fill in. docker compose reads .env from this directory.
# =============================================================================

# --- Postgres -----------------------------------------------------------------
POSTGRES_USER=syifa
POSTGRES_PASSWORD=syifa_dev
POSTGRES_DB=syifa

# --- Auth ---------------------------------------------------------------------
# Generate JWT_SECRET (32+ random chars):
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=replace-me-with-secrets-token-urlsafe-output

JWT_ACCESS_TTL_MIN=30
JWT_REFRESH_TTL_DAYS=30

# Generate FERNET_KEY (must be a real Fernet key, not arbitrary text):
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-me-with-Fernet.generate_key-output

# --- Google OAuth (optional; leave blank to disable Google sign-in) -----------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- CORS / cookies -----------------------------------------------------------
FRONTEND_ORIGIN=http://localhost:3000
# Set true behind HTTPS (production). Must be false on plain http://localhost.
COOKIE_SECURE=false

# --- S3-compatible blob store (defaults match the bundled localstack) ---------
# Production: point at AWS S3 / MinIO / Supabase Storage and rotate the keys.
S3_REGION=us-east-1
S3_BUCKET=syifa-papers
S3_ACCESS_KEY=test
S3_SECRET_KEY=test

# --- Ingest tuning ------------------------------------------------------------
# Reject uploads larger than this many bytes (default 50 MB).
PAPER_MAX_BYTES=50000000
# Chunk size for embedding (token-bounded; uses an approximate word-based heuristic).
PAPER_CHUNK_MAX_TOKENS=800
PAPER_CHUNK_OVERLAP=100
# Top-K nearest concepts for edge proposals; min cosine similarity to keep an edge.
CONCEPT_EDGE_TOP_K=5
CONCEPT_EDGE_MIN_COSINE=0.75

# --- Feynman ------------------------------------------------------------------
# Max non-system turns per session before /message returns 400.
FEYNMAN_MAX_TURNS=60

# --- Frontend -----------------------------------------------------------------
# Browser-side base URL for backend API calls. Must be reachable from the
# user's browser, not from inside the docker network.
NUXT_PUBLIC_API_BASE=http://localhost:8000
